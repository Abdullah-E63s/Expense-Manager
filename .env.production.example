# ============================================================
# Expense Manager — Production Environment Variables Template
# ============================================================
# Copy this file to .env and fill in all values before deploying.
# For Hugging Face Spaces, set these as Repository Secrets
# in Settings → Variables and secrets.
# ============================================================

# ── Core Flask ────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-64-char-hex-secret-here

# Environment (must be "production" on HF Spaces)
FLASK_ENV=production

# ── Database (Render MySQL) ───────────────────────────────────
# Get these from Render → Your Project → expense-manager-db → Connections tab
MYSQL_HOST=<hostname from Render Connections tab>
MYSQL_USER=<username from Render Connections tab>
MYSQL_PASSWORD=<password from Render Connections tab>
MYSQL_DATABASE=expense_manager
MYSQL_PORT=3306

# ── Admin Account ─────────────────────────────────────────────
# This admin user is auto-created/synced on startup.
ADMIN_EMAIL=your-admin@email.com
ADMIN_PASSWORD=your-secure-admin-password

# ── Email (Gmail SMTP) ────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your-gmail@gmail.com
# Use a Gmail App Password (not your main password):
# Google Account → Security → 2-Step Verification → App passwords
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=your-gmail@gmail.com

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Must match what you set in Google Cloud Console OAuth redirect URIs.
# For HF Spaces: https://YOUR-USERNAME-expense-manager.hf.space/api/auth/google/callback
GOOGLE_REDIRECT_URI=https://YOUR-USERNAME-expense-manager.hf.space/api/auth/google/callback

# ── Firebase (Google Sign-In) ─────────────────────────────────
# To generate FIREBASE_CREDENTIALS_BASE64:
#   Windows: [Convert]::ToBase64String([IO.File]::ReadAllBytes("firebase-credentials.json"))
#   Linux/Mac: base64 -w 0 firebase-credentials.json
FIREBASE_CREDENTIALS_BASE64=base64-encoded-content-of-firebase-credentials.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── reCAPTCHA Enterprise ──────────────────────────────────────
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
RECAPTCHA_ENTERPRISE_API_KEY=your-recaptcha-enterprise-api-key
RECAPTCHA_PROJECT_ID=your-gcp-project-id
RECAPTCHA_ENABLED=true
RECAPTCHA_MIN_SCORE=0.5

# ── AI / ML ───────────────────────────────────────────────────
# Path to YOLOv9 weights file (relative to app root)
YOLOV9_WEIGHTS=YOLOV9_MODEL/weights/best.pt

# ── URLs ──────────────────────────────────────────────────────
# The public-facing base URL of the Flask backend (no trailing slash).
# Used for email verification links and OAuth callbacks.
EXTERNAL_BASE_URL=https://YOUR-USERNAME-expense-manager.hf.space

# The Vercel deployment URL for the static/ folder CDN.
# Leave empty to serve static files directly from Flask (no CDN).
# e.g. https://expense-manager-static.vercel.app
STATIC_CDN_URL=https://your-project.vercel.app

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins for API requests.
# Must include your Vercel CDN domain if using static CDN.
ALLOWED_ORIGINS=https://YOUR-USERNAME-expense-manager.hf.space,https://your-project.vercel.app

# ── Gunicorn (optional overrides) ────────────────────────────
# HF Spaces sets PORT=7860 automatically — no need to set these
# unless you're self-hosting.
# GUNICORN_WORKERS=2
# GUNICORN_LOG_LEVEL=info
