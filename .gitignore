# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Sensitive credentials (NEVER commit these) ────────────────────────────────
.env
.env.*
firebase-credentials.json
*-firebase-adminsdk-*.json
*.pem
*.key

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Uploads and generated output ─────────────────────────────────────────────
static/images/uploads/
debug_crops/

# ── Database files (app uses MySQL; SQLite files are dev artifacts) ───────────
*.db
*.sqlite
*.sqlite3

# ── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE artifacts ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
tempCodeRunnerFile.py

# ── ML model weights (large binary files — store on cloud or mount as volume) ─
YOLOV9_MODEL/weights/*.pt

# ── Testing artifacts ─────────────────────────────────────────────────────────
test_processed.jpg
ml_out.txt
request.json

# ── Deployment artifacts ──────────────────────────────────────────────────────
# Vercel build output (local)
.vercel/
.vercel-output/

# Temp Firebase credentials decoded from base64 env var at runtime
firebase_cred_*.json

# Never commit the real .env — only the example template
.env
.env.*
!.env.production.example

# HF Spaces — do NOT commit model weights to git (use LFS or download at startup)
# YOLOV9_MODEL/weights/*.pt   # already listed above — keeping for clarity
