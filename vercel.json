{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "https://ghost993-expensemanager.hf.space/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' http://localhost:5173 https://abdullahjalal.sbs"
        }
      ]
    }
  ]
}
